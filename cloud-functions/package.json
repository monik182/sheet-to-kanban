{
  "name": "sheet-to-kanban-api",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && npx functions-framework --target=getSheet --source=dist",
    "dev": "npm run build && npx functions-framework --target=getSheet --source=dist --port=8080"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.5",
    "google-auth-library": "^9.15.1",
    "google-spreadsheet": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
